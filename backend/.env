# Application Settings
APP_NAME=EGP AI Procurement Intelligence Platform
APP_VERSION=1.0.0
APP_ENV=development
DEBUG=true

# Server
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
LOG_LEVEL=info

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=egp_db
DB_USER=egp_user
DB_PASSWORD=test_password
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10
DB_ECHO=false

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_CACHE_TTL=3600
REDIS_QUEUE_NAME=egp_tasks

# JWT Configuration
SECRET_KEY=your_super_secret_key_change_this_in_production_12345678901234567890
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Security
CORS_ORIGINS=["http://localhost:3000", "http://localhost:8000"]
TRUSTED_HOSTS=["localhost", "127.0.0.1"]

# Email/Notifications
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=noreply@egp-platform.com

# Telegram
TELEGRAM_BOT_TOKEN=

# External Services
EGP_PORTAL_URL=https://www.egp.gov.et

# Celery
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

